{
  "name": "orgcheck-sfdx-plugin",
  "description": "Org Check is an easy-to-install and easy-to-use Salesforce application in order to quickly analyze your org and its technical debt.",
  "version": "8.0.0",
  "private": true,
  "dependencies": {
    "@oclif/core": "^4",
    "@orgcheck/api": "8.0.0",
    "@salesforce/core": "^8.2.7",
    "@salesforce/sf-plugins-core": "^12",
    "fflate": "^0.8.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@oclif/plugin-command-snapshot": "^5.2.3",
    "@salesforce/cli-plugins-testkit": "^5.3.20",
    "@salesforce/dev-scripts": "^11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-sf-plugin": "^1.18.8",
    "eslint-plugin-unicorn": "^64.0.0",
    "jest": "^30.3.0",
    "oclif": "^4.14.0",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "/lib",
    "/messages",
    "/oclif.manifest.json",
    "/oclif.lock"
  ],
  "keywords": [
    "force",
    "salesforce",
    "salesforcedx",
    "sf",
    "sf-plugin",
    "sfdx",
    "sfdx-plugin"
  ],
  "license": "MIT",
  "oclif": {
    "commands": "./lib/commands",
    "bin": "sf",
    "topicSeparator": " ",
    "devPlugins": [
      "@oclif/plugin-help"
    ],
    "flexibleTaxonomy": true
  },
  "scripts": {
    "build": "yarn compile && yarn lint",
    "clean": "sf-clean",
    "clean-all": "sf-clean all",
    "compile": "tsc -p . --pretty --incremental",
    "docs": "sf-docs",
    "format": "prettier --write \"+(src|test|schemas)/**/*.+(ts|js|json)|command-snapshot.json\"",
    "link-check": "node -e \"process.exit(process.env.CI ? 0 : 1)\" || linkinator \"**/*.md\" --skip \"CHANGELOG.md|node_modules|test/|confluence.internal.salesforce.com|my.salesforce.com|localhost|%s\" --markdown --retry --directory-listing --verbosity error",
    "lint": "ESLINT_USE_FLAT_CONFIG=true eslint \"src/**/*.ts\" \"test/**/*.ts\" --color --cache --cache-location .eslintcache --no-error-on-unmatched-pattern",
    "postpack": "sf-clean --ignore-signing-artifacts",
    "prepack": "sf-prepack",
    "test": "yarn test:compile && yarn lint && yarn test:nut",
    "test:compile": "tsc -p \"./test\" --pretty",
    "test:nut": "yarn compile && jest",
    "test:command-reference": "node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" commandreference:generate --erroronwarnings",
    "test:deprecation-policy": "yarn compile && node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" snapshot:compare",
    "test:json-schema": "node --loader ts-node/esm --no-warnings=ExperimentalWarning \"./bin/dev.js\" schema:compare",
    "version": "oclif readme"
  },
  "publishConfig": {
    "access": "public"
  },
  "exports": "./lib/index.js",
  "type": "module",
  "author": "Vincent FINET"
}
