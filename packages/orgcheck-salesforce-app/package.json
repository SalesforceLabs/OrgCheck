{
    "name": "@orgcheck/salesforce-app",
    "version": "8.6.0",
    "license": "MIT",
    "private": true,
    "scripts": {
        "build": "node ./build/static-resource/build-static-resource.js",
        "test": "sfdx-lwc-jest",
        "sf:deploy": "sf project deploy start --metadata ApexPage --metadata AuraDefinitionBundle --metadata ContentAsset --metadata CustomApplication --metadata CustomTab --metadata LightningComponentBundle --metadata PermissionSet --metadata Prompt --metadata StaticResource",
        "sf:deploy:sr": "sf project deploy start --metadata StaticResource",
        "sf:deploy:lwc": "sf project deploy start --metadata LightningComponentBundle",
        "sf:deploy:lwc:app": "sf project deploy start --metadata LightningComponentBundle:orgcheckApp",
        "lint": "eslint force-app/main/default/lwc",
        "scan:lwc": "sf code-analyzer run --target './force-app/main/default/lwc/*/*.js' --output-file /tmp/orgcheck-lwc-scan.html; open /tmp/orgcheck-lwc-scan.html",
        "scan:securityreview": "sf code-analyzer run --rule-selector AppExchange --rule-selector Recommended:Security --output-file /tmp/orgcheck-security-scan.html; open /tmp/orgcheck-security-scan.html",
        "sf:open": "sf force org open",
        "sf:clean": "sf project deploy start --metadata-dir manifest/destructive",
        "git:clean": "git remote update origin --prune; git branch -vv | grep 'gone]' | awk '{print $1}' | xargs git branch -D ",
        "sanity:check": "yarn lint:api && yarn lint:ui && yarn lint:lwc && yarn test:unit && yarn scan:api && yarn scan:ui && yarn scan:lwc"
    },
    "devDependencies": {
        "@lwc/eslint-plugin-lwc": "^3.0.0",
        "@prettier/plugin-xml": "^3.4.2",
        "@sa11y/jest": "^8.0.27",
        "@salesforce/eslint-config-lwc": "^4.0.0",
        "@salesforce/eslint-plugin-lightning": "^2.0.0",
        "@salesforce/sfdx-lwc-jest": "^7.1.2",
        "baseline-browser-mapping": "^2.9.18",
        "eslint": "^10.0.3",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.0.1",
        "eslint-plugin-jsdoc": "^63.0.0",
        "fflate": "^0.8.2",
        "glob": "^13.0.6",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "js-yaml": "^4.1.1",
        "lint-staged": "^17.0.2",
        "lwc": "^9.0.2"
    },
    "dependencies": {
        "@orgcheck/api": "8.0.1"
    },
    "lint-staged": {
        "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
            "prettier --write"
        ],
        "**/lwc/**": [
            "sfdx-lwc-jest -- --bail --findRelatedTests --passWithNoTests"
        ]
    }
}
