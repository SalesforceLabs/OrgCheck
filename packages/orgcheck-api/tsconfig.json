{
    "compilerOptions": {
        "alwaysStrict": false, // to switch to true asap
        "allowSyntheticDefaultImports": true,
        "module": "ESNext",
        "moduleResolution": "node",
        "noImplicitAny": false, // to switch to true asap
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "pretty": true,
        "target": "es2015",
        "esModuleInterop": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "useUnknownInCatchVariables": false,
        "lib": [
            "ES2021",
            "DOM"
        ],
        "baseUrl": ".",
        "paths": {
            "tslib" :   [ "./node_modules/tslib/tslib.d.ts" ],
            "src/*":    [ "./src/*" ],
            "tests/*":  [ "./tests/*" ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}